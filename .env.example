# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password-here

# JWT Authentication
JWT_SECRET=your-jwt-secret-key-at-least-256-bits-long

# Google Maps
GOOGLE_MAPS_API_KEY=

# Email (optional - for password reset)
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=

# Event notification emails (comma-separated)
EVENT_NOTIFICATION_EMAILS=

# Stripe Payment (optional)
STRIPE_API_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Monitoring
GRAFANA_PASSWORD=admin

# ML Service Database
ML_DB_PASSWORD=your-secure-password-here

# Docker (optional)
DOCKERHUB_REPO=your-dockerhub-username/espritmarket-backend
IMAGE_TAG=latest
