# Database
ML_DB_PASSWORD=your-db-password
ML_DB_URL=postgresql://postgres:your-db-password@localhost:5432/esprit_market

# ML Model paths (relative to ml-service/)
BOOKING_MODEL_PATH=models/booking_completion_model.joblib
PROJECT_MODEL_PATH=models/project_delay_model.joblib
SENTIMENT_MODEL_PATH=models/sentiment_model.joblib

# Data directory
ML_DATA_DIR=data

# Retrain threshold (number of new records before auto-retrain)
RETRAIN_THRESHOLD=5
