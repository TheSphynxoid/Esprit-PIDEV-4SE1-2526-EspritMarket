@startuml events-sprint2-usecase
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

actor Organizer
actor Attendee

rectangle "Events Enhancements (Sprint 2)" {
    usecase "Create Online Event" as UC1
    usecase "Set Virtual Meeting Link" as UC2
    usecase "Join Online Event" as UC3
    usecase "Manage Waiting List" as UC4
    usecase "Auto-Promote from Waitlist" as UC5
    usecase "View Event Capacity" as UC6
}

Organizer --> UC1
Organizer --> UC2
Organizer --> UC4
Organizer --> UC6

Attendee --> UC3
Attendee --> UC4

UC1 ..> UC2 : <<include>>
UC4 ..> UC5 : <<include>>
UC4 ..> UC6 : <<include>>
UC3 ..> UC6 : <<extend>>
@enduml
