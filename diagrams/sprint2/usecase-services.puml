@startuml services-sprint2-usecase
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome

actor Provider
actor Client

rectangle "Services & Projects Enhancements (Sprint 2)" {
    usecase "Manage Recurring Availability" as UC1
    usecase "Set Weekly Schedule" as UC2
    usecase "Block Specific Dates" as UC3
    usecase "Track Project Milestones" as UC4
    usecase "View Milestone Progress" as UC5
    usecase "Update Milestone Status" as UC6
    usecase "Receive Deadline Alerts" as UC7
}

Provider --> UC1
Provider --> UC2
Provider --> UC3

Client --> UC4
Client --> UC5

Provider --> UC6
Provider --> UC7

UC1 ..> UC2 : <<include>>
UC1 ..> UC3 : <<extend>>
UC4 ..> UC5 : <<include>>
UC4 ..> UC7 : <<extend>>
@enduml
